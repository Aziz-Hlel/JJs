{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "rootDir": "../../",
    "outDir": "dist",

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@contracts/*": ["../../packages/contracts/src/*"]
    }
  },
  "include": ["src/**/*", "src/index.ts", "../../packages/contracts/src/**/*"]
}
