{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@repo/contracts/*": ["../../packages/contracts/src/*"]
    }
  },
  "references": [{ "path": "../../packages/contracts" }],
  "include": ["src/**/*", "../../packages/contracts/src/**/*"]
}
