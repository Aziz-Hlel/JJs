COMPOSE_PROJECT_NAME=jj-dev
COMPOSE_BAKE=true

# API

NODE_ENV=dev
API_PORT=5000
ALLOWED_ORIGIN_PATTERNS=http://localhost:*

IOS_MIN_SUPPORTED_VER=0.0.0
ANDROID_MIN_SUPPORTED_VER=0.0.0

# ADMIN
VITE_NODE_ENV=dev
VITE_API_URL=http://localhost:5000/api  
VITE_ADMIN_PORT=5002

# DB 
DB_HOST=db
DB_USER=user
DB_PASSWORD=password
DB_NAME=mydb
DB_PORT=5432

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=password

# MINIO
MINIO_REGION=us-east-1
MINIO_ROOT_USER=MINIO_ROOT_USER
MINIO_ROOT_PASSWORD=MINIO_ROOT_PASSWORD
MINIO_BUCKET=jj-local-bucket
MINIO_PORT=9000
MINIO_UI_PORT=9001

# SMTP
SMTP_HOST=mailpit
SMTP_UI_PORT=2025
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=no-reply@baseMonorepo.com
SMTP_PASS=xxx