:3000 {

    # -----------------------
    # API reverse proxy
    # -----------------------
    handle /api/* {
        reverse_proxy api:3000
    }

    handle /* {
        reverse_proxy web:3000
    }

	
    log {
		level ERROR
        format console
    }
}



# -----------------------
# Admin panel
# -----------------------
:3001 {
    root * /srv/admin
    encode gzip
    file_server
    try_files {path} /index.html

    log {
		level ERROR
        format console
    }
}
