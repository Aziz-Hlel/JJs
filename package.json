{
  "name": "mono-repo",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "scripts": {
    "prepare": "husky",
    "format:fix": "prettier --write .",
    "local": "node scripts/docker-up.js local",
    "dev-api": "cd apps/api && pnpm dev",
    "dev-admin": "cd apps/admin && pnpm dev",
    "dev": "pnpm -r --parallel --filter ./apps/api --filter ./apps/admin dev",
    "docker:dev": "node scripts/docker-up.js dev",
    "docker:stage": "node scripts/docker-up.js stage",
    "test": ""
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "lint-staged": "^16.2.7"
  }
}
