{
  "name": "mono-repo",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "scripts": {
    "prepare": "husky",
    "format:fix": "prettier --write .",
    "prisma:generate": "pnpm --filter api exec prisma generate",
    "prisma:migrate:dev": "pnpm --filter api exec prisma migrate dev",
    "docker:local": "node scripts/docker-up.js local",
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev": "pnpm -r --parallel --filter api --filter admin --filter web dev",
    "docker:dev": "node scripts/docker-up.js dev",
    "docker:stage": "node scripts/docker-up.js stage",
    "docker:prod": "node scripts/docker-up.js prod ",
    "build": "tsc -b",
    "start": "pnpm -r --filter api start",
    "test": ""
  },
  "lint-staged": {
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.17.0",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "lint-staged": "^16.2.7"
  }
}
